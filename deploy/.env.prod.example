APP_NAME=Telegram AI Video Automation
APP_ENV=production
SECRET_KEY=change-me
APP_ENCRYPTION_KEY=change-me-too
DATABASE_URL=postgresql+psycopg://sosyal:sosyal-change-me@postgres:5432/sosyal
STORAGE_PATH=storage/videos
PROMPT_RETENTION_HOURS=24
VIDEO_RETENTION_HOURS=24
DEFAULT_TELEGRAM_USER_ID=123456789
DEFAULT_TELEGRAM_CHAT_ID=123456789
DEFAULT_TIMEZONE=Europe/Istanbul
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TRENDS_PROVIDER=ollama
PROMPT_PROVIDER=ollama
VIDEO_PROVIDER=kling
OLLAMA_API_BASE=http://ollama:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_RESEARCH_MODEL=deepseek-r1:32b
OLLAMA_PROMPT_MODEL=qwen3:32b
OLLAMA_FALLBACK_MODEL=qwen3:32b
OLLAMA_TIMEOUT_SECONDS=240
OLLAMA_AUTO_BENCHMARK=true
INTERNAL_AGENT_TOKEN=change-internal-agent-token
PIAPI_BASE_URL=https://api.piapi.ai
PIAPI_API_KEY=
PIAPI_SERVICE_MODE=public
KLING_MODEL=kling
KLING_VERSION=3.0
KLING_DEFAULT_MODE=std
KLING_DEFAULT_DURATION=5
KLING_DEFAULT_ASPECT_RATIO=9:16
KLING_ENABLE_AUDIO=false
COVER_IMAGE_PROVIDER=flux
FLUX_MODEL=Qubico/flux1-schnell
COVER_IMAGE_POLL_ATTEMPTS=10
COVER_IMAGE_POLL_INTERVAL_SECONDS=3.0
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=
